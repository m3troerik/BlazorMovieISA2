@page "/movies/details"
@using Abc.Infra
@using Microsoft.EntityFrameworkCore
@inject IMoviesRepo repo
@inject NavigationManager NavigationManager
@using Abc.Data
<MyDetailsPage
	PageTitleText="Details Movie"
	EntityTitle="Movie"
	Entity="movie"
	EntityId="movie?.Id"
	BasePath="/movies" />
@code {
    private Movie movie;
    [SupplyParameterFromQuery] private int Id { get; set; }
    protected override async Task OnInitializedAsync() {
		movie = await repo.GetAsync(Id);
        if (movie is null)
        {
	        NavigationManager.NavigateTo("/404");
        }
    }
}
