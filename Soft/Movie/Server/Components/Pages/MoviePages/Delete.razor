@page "/movies/delete"
@using Abc.Infra
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AbcSoftMoviesContext> DbFactory
@inject NavigationManager NavigationManager
@using Abc.Data
@inject IMoviesRepo repo

<MyDeletePage PageTitleText="Delete Movie" EntityTitle="Movie" Entity="movie" BasePath="/movies" OnValidSubmit="deleteMovie" />


@code {
	private Movie movie;

	[SupplyParameterFromQuery]
	private int Id { get; set; }

	protected override async Task OnInitializedAsync()
	{
		movie = await repo.GetAsync(Id);
		if (movie is null)
		{
			NavigationManager.NavigateTo("/404", true);
			return;
		}
	}

	private async Task deleteMovie()
	{
		await repo.DeleteAsync(movie!.Id);
		NavigationManager.NavigateTo("/movies");
	}
}