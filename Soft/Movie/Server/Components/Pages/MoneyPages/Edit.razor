@page "/monies/edit"
@using Abc.Data
@using Abc.Infra
@inject IMoniesRepo repo
@inject NavigationManager NavigationManager

<MyEditPage
	PageTitleText="Edit Money"
	EntityTitle="Money"
	Entity="item"
	BasePath="/monies"
	EntityId="@Id"
	OnValidSubmit="update" />

@code {
	[SupplyParameterFromQuery] private int Id { get; set; }
	[SupplyParameterFromForm] private Money item { get; set; }

	protected override async Task OnInitializedAsync() {
		item ??= await repo.GetAsync(Id);
		if (item is null) NavigationManager.NavigateTo("/404", true);
	}

	private async Task update() {
		await repo.UpdateAsync(item!);
		NavigationManager.NavigateTo("/monies");
	}
}