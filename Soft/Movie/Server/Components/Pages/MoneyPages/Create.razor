@page "/monies/create"
@using Abc.Data
@using Abc.Infra
@inject IMoniesRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage Entity="item" EntityTitle="Money" BasePath="/monies" OnValidSubmit="add" />

@code {
	[SupplyParameterFromForm] private Money money { get; set; } = default!;
	protected override void OnInitialized() => money ??= new();
	private async Task add() {
		await repo.CreateAsync(money);
		NavigationManager.NavigateTo("/monies");
	}
}