@page "/countrycurrencies/delete"
@using Abc.Infra
@using Abc.Data
@using CountryCurrencyData = Abc.Data.CountryCurrency
@inject ICountryCurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyDeletePage PageTitleText="Delete Country Currency"
              EntityTitle="Country Currency"
              Entity="item" BasePath="/countrycurrencies" OnValidSubmit="delete" />

@code {
   private CountryCurrencyData item;
	[SupplyParameterFromQuery] private int Id { get; set; }

	protected override async Task OnInitializedAsync() {
		item = await repo.GetAsync(Id);
		if (item is null) NavigationManager.NavigateTo("/404", true);
	}

	private async Task delete() {
		await repo.DeleteAsync(item!.Id);
		NavigationManager.NavigateTo("/countrycurrencies");
	}
}