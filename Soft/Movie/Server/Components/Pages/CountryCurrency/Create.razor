@using Abc.Data
@page "/countrycurrencies/create"
@using Abc.Infra
@inject ICountryCurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage
	Entity="item"
	EntityTitle="Country Currencies"
	BasePath="/countrycurrencies"
	OnValidSubmit="add" />

@code {
	[SupplyParameterFromQuery] private int Id { get; set; }
	[SupplyParameterFromForm(Name = nameof(CountryCurrency))] private CountryCurrency item { get; set; }

	protected override async Task OnInitializedAsync() {
		item ??= await repo.GetAsync(Id);
		if (item is null) NavigationManager.NavigateTo("/404", true);
	}

	private async Task update() {
		await repo.UpdateAsync(item!);
		NavigationManager.NavigateTo("/countrycurrencies");
	}
}