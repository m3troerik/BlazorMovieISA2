@using Abc.Data
@using CountryCurrencyData = Abc.Data.CountryCurrency
@page "/countrycurrencies/create"
@using Abc.Infra
@inject ICountryCurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage
	Entity="item"
	EntityTitle="Country Currencies"
	BasePath="/countrycurrencies"
	OnValidSubmit="add" />

@code {
 [SupplyParameterFromForm(Name = nameof(CountryCurrencyData))] private CountryCurrencyData item { get; set; }

    protected override void OnInitialized() {
		item ??= new();
	}

   private async Task add() {
		await repo.CreateAsync(item!);
		NavigationManager.NavigateTo("/countrycurrencies");
	}
}