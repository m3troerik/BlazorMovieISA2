@page "/countrycurrencies/details"
@using Abc.Infra
@inject ICountryCurrenciesRepo repo
@inject NavigationManager NavigationManager
@using Abc.Data
@using CountryCurrencyData = Abc.Data.CountryCurrency
<MyDetailsPage
	PageTitleText="Details Country Currency"
	EntityTitle="Country Currency"
	Entity="item"
	EntityId="item?.Id"
	BasePath="/countrycurrencies" />
@code {
   private CountryCurrencyData item;
	[SupplyParameterFromQuery] private int Id { get; set; }

	protected override async Task OnInitializedAsync() {
		item = await repo.GetAsync(Id);
		if (item is null) NavigationManager.NavigateTo("/404", true);
    }
}
