@page "/countrycurrencies"

@using Abc.Data
@using CountryCurrencyData = Abc.Data.CountryCurrency
@using Abc.Infra
@inject ICountryCurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyIndexPage
 TItem="CountryCurrencyData"
	PageTitleText="Country Currencies Page"
	EntityTitle="Country Currency"
	Items="items"
	BasePath="/countrycurrencies">
</MyIndexPage>

@code {
  private IQueryable<CountryCurrencyData> items = Enumerable.Empty<CountryCurrencyData>().AsQueryable();

	protected override async Task OnInitializedAsync() {
		if (repo is null) return;
		items = (await repo.GetAsync()).AsQueryable();
	}
}