@page "/countrycurrencies/edit"
@inject ICountryCurrenciesRepo repo
@inject NavigationManager NavigationManager
@using Abc.Data
@using Abc.Infra

<MyEditPage
	PageTitleText="Edit Country Currency"
	EntityTitle="Country Currency"
	Entity="item"
	BasePath="/countrycurrencies"
	EntityId="@Id"
	OnValidSubmit="update" />

@code {
	[SupplyParameterFromQuery] private int Id { get; set; }
	[SupplyParameterFromForm] private CountryCurrency item { get; set; }

	protected override async Task OnInitializedAsync() {
		item ??= await repo.GetAsync(Id);
		if (item is null) NavigationManager.NavigateTo("/404", true);
	}

	private async Task update() {
		await repo.UpdateAsync(item!);
		NavigationManager.NavigateTo("/countrycurrencies");
	}
}